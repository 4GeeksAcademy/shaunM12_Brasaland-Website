{
  "rewrites": [
    {
      "source": "/",
      "destination": "/apps/brasaland-webpage/index.html"
    },
    {
      "source": "/application",
      "destination": "/apps/brasaland-webpage/application.html"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/brasaland-webpage/$1"
    }
  ]
}
