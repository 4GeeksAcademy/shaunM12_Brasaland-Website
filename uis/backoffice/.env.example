# Tracker API base URL
NEXT_PUBLIC_TRACKER_API_BASE_URL=https://playground.4geeks.com/tracker/api/v1

# Backoffice API proxy target for incidents + suppliers (optional — defaults to http://127.0.0.1:8000)
# BACKOFFICE_API_PROXY_TARGET=http://127.0.0.1:8000
# INCIDENTS_API_PROXY_TARGET=http://127.0.0.1:8000

# Direct API base URLs (optional — leave unset to use Next.js rewrites)
# NEXT_PUBLIC_INCIDENTS_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_SUPPLIERS_API_BASE_URL=http://localhost:8000
