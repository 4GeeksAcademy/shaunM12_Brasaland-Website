# Copy this file to .env (which is gitignored) and fill in real values.
# Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_ALGORITHM=HS256

# Refresh tokens & auth cookie
REFRESH_TOKEN_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=brasaland_refresh
# Set to true in production (HTTPS); keep false for local http dev.
COOKIE_SECURE=false

# Email verification
EMAIL_VERIFICATION_EXPIRES_HOURS=24
# Base URL of the backoffice; used to build links in (stubbed) verification emails.
FRONTEND_BASE_URL=http://localhost:3000
