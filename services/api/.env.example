# Copy this file to .env (which is gitignored) and fill in real values.
# Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"

# --- JWT / access tokens -----------------------------------------------------
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_ALGORITHM=HS256

# --- Refresh tokens & auth cookie --------------------------------------------
REFRESH_TOKEN_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=brasaland_refresh
# Set COOKIE_SECURE=true in production (HTTPS). Leave false for local http dev.
COOKIE_SECURE=false

# --- Email verification ------------------------------------------------------
EMAIL_VERIFICATION_EXPIRES_HOURS=24
# Base URL of the backoffice, used to build links in emails.
FRONTEND_BASE_URL=http://localhost:3000

# --- Password reset ----------------------------------------------------------
PASSWORD_RESET_EXPIRES_MINUTES=30
RESET_REQUESTS_PER_HOUR=10

# --- Transactional email -----------------------------------------------------
# Provider backend: console (dev default), resend, or sendgrid.
EMAIL_PROVIDER=console
# Verified/onboarding sender address (Resend's onboarding sender needs no domain).
EMAIL_FROM=onboarding@resend.dev
# API keys are read from the environment ONLY — never commit real values.
# Set the one matching EMAIL_PROVIDER:
RESEND_API_KEY=
SENDGRID_API_KEY=
